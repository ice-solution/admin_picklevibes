{
  "name": "picklevibes-admin",
  "version": "1.0.0",
  "private": true,
  "description": "Pickle Vibes internal admin — receipts, income & expense P&L",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "NODE_ENV=development nodemon src/app.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14"
  }
}
