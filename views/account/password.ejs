<%- include('../partials/shell-open') %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">更改密碼</h1>
  <p class="text-sm text-slate-500">首次登入需先更改密碼後才可使用系統。</p>
</div>

<% if (error) { %>
<div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800"><%= error %></div>
<% } %>
<% if (success) { %>
<div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800"><%= success %></div>
<% } %>

<form action="/account/password" method="post" class="max-w-xl space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <% if (!mustChangePassword) { %>
  <div>
    <label class="block text-sm font-medium text-slate-700">目前密碼</label>
    <input name="currentPassword" type="password" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-pink focus:outline-none focus:ring-2 focus:ring-brand-pink/30" />
  </div>
  <% } %>
  <div>
    <label class="block text-sm font-medium text-slate-700">新密碼（至少 8 字元）</label>
    <input name="newPassword" type="password" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-pink focus:outline-none focus:ring-2 focus:ring-brand-pink/30" />
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">確認新密碼</label>
    <input name="newPasswordConfirm" type="password" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-pink focus:outline-none focus:ring-2 focus:ring-brand-pink/30" />
  </div>
  <div class="flex flex-wrap gap-3 pt-2">
    <button type="submit" class="rounded-xl bg-brand-pink px-5 py-2.5 font-semibold text-white shadow-md shadow-brand-pink/25 hover:brightness-110">更新密碼</button>
    <button type="submit" form="logout-form" class="rounded-xl border border-slate-200 px-5 py-2.5 font-medium text-slate-600 hover:bg-slate-50">登出</button>
  </div>
</form>
<form id="logout-form" action="/logout" method="post"></form>
<%- include('../partials/shell-close') %>

