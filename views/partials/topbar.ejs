<header class="sticky top-0 z-20 flex h-14 items-center gap-3 border-b border-slate-200 bg-white/95 px-4 backdrop-blur lg:hidden">
  <button type="button" id="menu-btn" class="rounded-lg p-2 text-slate-600 hover:bg-slate-100" aria-label="開啟選單">
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
  </button>
  <span class="font-semibold text-slate-800"><%= typeof title !== 'undefined' ? title : 'Pickle Vibes' %></span>
</header>
<script>
  (function () {
    var btn = document.getElementById('menu-btn');
    var side = document.getElementById('sidebar');
    var back = document.getElementById('sidebar-backdrop');
    if (!btn || !side || !back) return;
    function open() {
      side.classList.remove('-translate-x-full');
      back.classList.remove('hidden');
    }
    function close() {
      side.classList.add('-translate-x-full');
      back.classList.add('hidden');
    }
    btn.addEventListener('click', function () {
      if (side.classList.contains('-translate-x-full')) open(); else close();
    });
    back.addEventListener('click', close);
  })();
</script>
