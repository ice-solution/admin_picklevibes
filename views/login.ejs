<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="flex min-h-screen flex-col items-center justify-center bg-gradient-to-br from-white via-slate-50 to-brand-cyan/5 px-4">
    <div class="mb-8 flex flex-col items-center">
      <img src="/images/logo.png" alt="Pickle Vibes" class="h-24 w-auto object-contain drop-shadow-sm md:h-28" />
      <p class="mt-2 text-sm text-slate-500">內部管理系統</p>
    </div>
    <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-8 shadow-lg shadow-brand-pink/5">
      <h1 class="text-lg font-semibold text-slate-800">登入</h1>
      <% if (error) { %>
      <p class="mt-3 rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700"><%= error %></p>
      <% } %>
      <form action="/login" method="post" class="mt-6 space-y-4">
        <input type="hidden" name="returnTo" value="<%= returnTo %>" />
        <div>
          <label class="block text-sm font-medium text-slate-700">帳號</label>
          <input name="username" autocomplete="username" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 shadow-sm focus:border-brand-pink focus:outline-none focus:ring-2 focus:ring-brand-pink/30" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700">密碼</label>
          <input name="password" type="password" autocomplete="current-password" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 shadow-sm focus:border-brand-pink focus:outline-none focus:ring-2 focus:ring-brand-pink/30" />
        </div>
        <button type="submit" class="w-full rounded-xl bg-brand-pink px-4 py-2.5 font-semibold text-white shadow-md shadow-brand-pink/25 transition hover:brightness-110">登入</button>
      </form>
    </div>
    <p class="mt-8 text-center text-xs text-slate-400">© Pickle Vibes</p>
  </body>
</html>
